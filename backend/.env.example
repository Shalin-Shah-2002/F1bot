APP_NAME=F1bot API
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

GEMINI_API_KEY=
GEMINI_MODEL_LITE=gemini-2.5-flash-lite
# Deprecated/unused in current Lite-only lead scoring flow:
GEMINI_MODEL_MAIN=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=f1bot-local
# Defaults to true in local/dev/test and false otherwise when unset.
SAMPLE_LEADS_FALLBACK_ENABLED=

SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key is optional and should be used only for admin/background tasks.
SUPABASE_SERVICE_ROLE_KEY=
# Secure default: keep Supabase auth enabled unless explicitly doing local fallback.
SUPABASE_AUTH_ENABLED=true
# Local/demo fallback is disabled by default. Enable only for local/dev/test usage.
LOCAL_AUTH_FALLBACK_ENABLED=false

SCAN_RATE_LIMIT_PER_MINUTE=6
SCAN_RATE_LIMIT_WINDOW_SECONDS=60
SCAN_DAILY_QUOTA=200

# Persistent rate-limit state backend.
# Use redis for shared counters/lockouts across instances.
RATE_LIMIT_STORE=redis
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=f1bot:ratelimit

AUTH_RATE_LIMIT_PER_IP=20
AUTH_RATE_LIMIT_PER_IDENTITY=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_BASE_SECONDS=30
AUTH_LOCKOUT_MAX_SECONDS=900
# Comma-separated proxy IP/CIDRs trusted to supply X-Forwarded-For (empty by default).
TRUSTED_PROXY_CIDRS=
