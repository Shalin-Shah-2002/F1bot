  "components": {
    "schemas": {
      "BusinessProfile": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "business_description": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 10,
            "title": "Business Description"
          },
          "keywords": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Keywords"
          },
          "subreddits": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Subreddits"
          },
          "updated_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "business_description"
        ],
        "title": "BusinessProfile"
      },
      "CandidatePost": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "body": {
            "type": "string",
            "title": "Body"
          },
          "subreddit": {
            "type": "string",
            "title": "Subreddit"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "author": {
            "type": "string",
            "title": "Author"
          },
          "created_utc": {
            "type": "string",
            "format": "date-time",
            "title": "Created Utc"
          },
          "score": {
            "type": "integer",
            "title": "Score"
          },
          "num_comments": {
            "type": "integer",
            "title": "Num Comments"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "body",
          "subreddit",
          "url",
          "author",
          "created_utc",
          "score",
          "num_comments"
        ],
        "title": "CandidatePost"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LeadInsight": {
        "properties": {
          "post": {
            "$ref": "#/components/schemas/CandidatePost"
          },
          "lead_score": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Lead Score"
          },
          "qualification_reason": {
            "type": "string",
            "title": "Qualification Reason"
          },
          "suggested_outreach": {
            "type": "string",
            "title": "Suggested Outreach"
          }
        },
        "type": "object",
        "required": [
          "post",
          "lead_score",
          "qualification_reason",
          "suggested_outreach"
        ],
        "title": "LeadInsight"
      },
      "LeadListResponse": {
        "properties": {
          "leads": {
            "items": {
              "$ref": "#/components/schemas/LeadRecord"
            },
            "type": "array",
            "title": "Leads"
          }
        },
        "type": "object",
        "required": [
          "leads"
        ],
        "title": "LeadListResponse"
      },
      "LeadRecord": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "contacted",
              "qualified",
              "ignored"
            ],
            "title": "Status",
            "default": "new"
          },
          "post": {
            "$ref": "#/components/schemas/CandidatePost"
          },
          "lead_score": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Lead Score"
          },
          "qualification_reason": {
            "type": "string",
            "title": "Qualification Reason"
          },
          "suggested_outreach": {
            "type": "string",
            "title": "Suggested Outreach"
          },
          "scan_id": {
            "type": "string",
            "title": "Scan Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "post",
          "lead_score",
          "qualification_reason",
          "suggested_outreach",
          "scan_id",
          "created_at",
          "updated_at"
        ],
        "title": "LeadRecord"
      },
      "LeadScanRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "default": "demo-user"
          },
          "business_description": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 10,
            "title": "Business Description"
          },
          "keywords": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Keywords"
          },
          "subreddits": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Subreddits"
          },
          "limit": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 20
          }
        },
        "type": "object",
        "required": [
          "business_description"
        ],
        "title": "LeadScanRequest"
      },
      "LeadScanResponse": {
        "properties": {
          "leads": {
            "items": {
              "$ref": "#/components/schemas/LeadInsight"
            },
            "type": "array",
            "title": "Leads"
          },
          "total_candidates": {
            "type": "integer",
            "title": "Total Candidates"
          },
          "used_ai": {
            "type": "boolean",
            "title": "Used Ai"
          }
        },
        "type": "object",
        "required": [
          "leads",
          "total_candidates",
          "used_ai"
        ],
        "title": "LeadScanResponse"
      },
      "LeadStatusUpdateRequest": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "new",
              "contacted",
              "qualified",
              "ignored"
            ],
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "LeadStatusUpdateRequest"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "minLength": 3,
            "title": "Email"
          },
          "password": {
            "type": "string",
            "minLength": 3,
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "LoginResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "email",
          "access_token"
        ],
        "title": "LoginResponse"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "type": "string",
            "minLength": 3,
            "title": "Email"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "title": "Password"
          },
          "full_name": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ],
            "title": "Full Name"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "RegisterRequest"
      },
      "RegisterResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "email",
          "access_token"
        ],
        "title": "RegisterResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}